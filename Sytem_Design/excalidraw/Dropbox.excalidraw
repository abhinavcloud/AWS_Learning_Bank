      "type": "text",
      "x": 745.299438169905,
      "y": 1670.0491477139917,
      "width": 787.99951171875,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3N",
      "roundness": null,
      "seed": 234377834,
      "version": 21,
      "versionNonce": 823322870,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1784043980024,
      "link": null,
      "locked": false,
      "text": "Its more for the objects to be avaialble across devices even if they are not the\nmost updated version",

      "seed": 1347540778,
      "version": 182,
      "versionNonce": 1746217270,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784039769456,
      "link": null,
      "locked": false,
      "text": "1. Remote file changed\n- Pull for changes\n- download the new file\nand replace\n\n\n2. Local File changed\n- upload the changed \nfile",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Remote file changed\n- Pull for changes\n- download the new file\nand replace\n\n\n2. Local File changed\n- upload the changed \nfile",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "mH0GARkHomyzUH8ylSXRU",
      "type": "text",
      "x": 1776.0952380952383,
      "y": 1648.3095238095239,
      "width": 793.4594116210938,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3F",
      "roundness": null,
      "seed": 1346616170,
      "version": 627,
      "versionNonce": 690748970,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784040104739,
      "link": null,
      "locked": false,
      "text": "Sync Local from Remote (Pull Changes to local)\nif local fileMetadata timestamp and versions are lesser than remote fileMetadata",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Sync Local from Remote (Pull Changes to local)\nif local fileMetadata timestamp and versions are lesser than remote fileMetadata",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "goJQpBjsQnxogjoHzK71Z",
      "type": "text",
      "x": 100.79761904761949,
      "y": 1418.488095238095,
      "width": 305.4198303222656,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3G",
      "roundness": null,
      "seed": 1925815414,
      "version": 310,
      "versionNonce": 1388471210,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784039933771,
      "link": null,
      "locked": false,
      "text": "Each os provide an api to\ntrack local changes\n- windows API\n       - FileSystemWatcher\n- MacOS API\n       - FSEvents\n\nIf there is a change in local \nthen follow the uploadFile path",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Each os provide an api to\ntrack local changes\n- windows API\n       - FileSystemWatcher\n- MacOS API\n       - FSEvents\n\nIf there is a change in local \nthen follow the uploadFile path",
      "autoResize": true,
      "lineHeight": 1.25
    },

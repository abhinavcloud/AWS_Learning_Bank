    {
      "id": "MQnCH3FKKOC4ImU2lqbyM",
      "type": "text",
      "x": 95.38095238095235,
      "y": 1182.4166666666665,
      "width": 227.1398468017578,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],

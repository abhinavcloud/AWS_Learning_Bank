    {
      "id": "gPW2ujffooscKtdPt3Fwn",
      "type": "text",
      "x": 31.000000000000114,
      "y": 69.83333333333337,
      "width": 1038.139404296875,
      "height": 525,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,

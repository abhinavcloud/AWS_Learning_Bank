    {
      "id": "KxoxAmtiieSGNC9JDq62v",
      "type": "text",
      "x": 941.8493344101394,
      "y": 1777.5491477139917,
      "width": 394.89971923828125,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3P",

      "seed": 1330322826,
      "version": 1075,
      "versionNonce": 577798038,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784526112837,
      "link": null,
      "locked": false,
      "text": "Design WhatsApp\n\nRequirements -> Core Entities -> APIs -> HLD -> Deep Dives\n\nFunctional Requirements:\n1. User should be able to view all the chats\n2. User should be able to send messages in a chat\n3. User should be able to receive messages in a chat\n4. User should be able to send media in a chat\n5. User should be able to receive media in a chat\n6. User should be able to receive all the unread messages when coming online\n\n--below the line--\n# User should be able to see the status of the other users\n\nNon Functional Requirements\n1. Low Latency - User should be able to send and receive messages quickly < 500 ms\n2. Guarantee Message delivery\n3. Billions of Users - high throughput\n4. Messages should be deleted  on ttl\n5. Fault Tolerant",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Design WhatsApp\n\nRequirements -> Core Entities -> APIs -> HLD -> Deep Dives\n\nFunctional Requirements:\n1. User should be able to view all the chats\n2. User should be able to send messages in a chat\n3. User should be able to receive messages in a chat\n4. User should be able to send media in a chat\n5. User should be able to receive media in a chat\n6. User should be able to receive all the unread messages when coming online\n\n--below the line--\n# User should be able to see the status of the other users\n\nNon Functional Requirements\n1. Low Latency - User should be able to send and receive messages quickly < 500 ms\n2. Guarantee Message delivery\n3. Billions of Users - high throughput\n4. Messages should be deleted  on ttl\n5. Fault Tolerant",
      "autoResize": true,
      "lineHeight": 1.25
    },
